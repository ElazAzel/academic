NODE_ENV=development
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-plus-random-chars
# For docker-compose app container. Host-local scripts should use an explicit local-only port-forward if needed.
DATABASE_URL=postgresql://academy:replace-with-internal-db-password@postgres:5432/academy?schema=public
REDIS_URL=redis://localhost:6379

# Self-hosted internal PostgreSQL for docker-compose/Kubernetes.
# Keep this value only in local/VPS/Kubernetes secrets; never commit real passwords.
POSTGRES_PASSWORD=replace-with-internal-db-password

# OAuth examples
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email
EMAIL_FROM="AI Strategic Academy <noreply@example.com>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# S3-compatible storage. Local defaults target MinIO from docker-compose.
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=academy-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=replace-with-internal-minio-password

# Feature flags
NEXT_PUBLIC_DEMO_MODE=false
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_GRAPHQL=false
FEATURE_TELEGRAM_NOTIFICATIONS=false
CERTIFICATE_COMPLETION_THRESHOLD=85
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
NEXT_OUTPUT_MODE=

# Bulk account provisioning and temporary seeding.
# SEED_USER_PASSWORD is used by /api/seed-temp for initial demo user creation.
SEED_USER_PASSWORD=replace-with-secure-password
PROVISION_STUDENT_COUNT=4000
PROVISION_CURATOR_COUNT=50
PROVISION_EMAIL_DOMAIN=academy.local
PROVISION_OUTPUT_DIR=var/credentials
PROVISION_RESET_EXISTING_PASSWORDS=false
