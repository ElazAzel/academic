NODE_ENV=development
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-plus-random-chars
# For docker-compose app container. Host-local scripts should use an explicit local-only port-forward if needed.
DATABASE_URL=postgresql://academy:replace-with-internal-db-password@postgres:5432/academy?schema=public
REDIS_URL=redis://localhost:6379
# Vercel KV (Upstash Redis) for caching & rate limiting in production
# KV_URL=redis://default:password@host.upstash.io:6379
# KV_REST_API_TOKEN=your-token

# Self-hosted internal PostgreSQL for docker-compose/Kubernetes.
# Keep this value only in local/VPS/Kubernetes secrets; never commit real passwords.
POSTGRES_PASSWORD=replace-with-internal-db-password

# OAuth examples
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (отключено по умолчанию — уведомления только через браузер/PWA).
# FEATURE_EMAIL_NOTIFICATIONS=true
# EMAIL_FROM="AI Strategic Academy <noreply@example.com>"
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=

# S3-compatible storage. Local defaults target MinIO from docker-compose.
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=academy-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=replace-with-internal-minio-password

# Feature flags
NEXT_PUBLIC_DEMO_MODE=false
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_GRAPHQL=false
# FEATURE_TELEGRAM_NOTIFICATIONS=false (удалено — все уведомления через браузер/PWA)

# Web Push (VAPID) — generate keys with: npx web-push generate-vapid-keys
# Both VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY must be the same value
# VAPID_PUBLIC_KEY is used server-side, NEXT_PUBLIC_VAPID_PUBLIC_KEY is used client-side
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
CERTIFICATE_COMPLETION_THRESHOLD=85
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
NEXT_OUTPUT_MODE=

# Monitoring
SENTRY_DSN=

# Cron / Scheduled Jobs — опционально (мин. 16 символов).
# Нужен только если вы настраиваете внешний cron-сервис для outbox/отчётов.
# Для Vercel Hobby cron-джобы недоступны — удалены.
# CRON_SECRET=replace-with-32-plus-random-chars

# ─── Supabase (main — realtime, auth) ─────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase Storage (отдельный проект для медиа-файлов — чат, вложения) ───
# STORAGE_SUPABASE_URL=https://your-storage-project.supabase.co
# STORAGE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bulk account provisioning and temporary seeding.
# SEED_ADMIN_TOKEN is used by /api/seed-temp for dev seeding (min 16 chars).
# db:push, db:seed and certificate:issue-demo refuse non-local database hosts by default.
# Set ALLOW_REMOTE_DATABASE_MUTATION=true only for an intentional remote mutation.
SEED_ADMIN_TOKEN=
PROVISION_STUDENT_COUNT=4000
PROVISION_CURATOR_COUNT=50
PROVISION_EMAIL_DOMAIN=academy.local
PROVISION_OUTPUT_DIR=var/credentials
PROVISION_RESET_EXISTING_PASSWORDS=false
