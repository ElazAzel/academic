{
  "name": "ai-strategic-academy",
  "version": "0.1.0",
  "private": true,
  "description": "Closed academy LMS for AI Strategic Academy.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "users:provision": "tsx scripts/provision-users.ts",
    "verify": "npm run lint -- --max-warnings=0 && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "1.0.7",
    "@node-rs/argon2": "2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "1.1.1",
    "@tanstack/react-query": "5.91.2",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "ioredis": "^5.10.1",
    "lucide-react": "0.468.0",
    "next": "16.2.5",
    "next-auth": "4.24.11",
    "nodemailer": "^8.0.7",
    "pdf-lib": "1.17.1",
    "pg": "^8.20.0",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "2.6.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@playwright/test": "1.58.2",
    "@types/node": "24.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "1.5.5",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.22",
    "eslint": "9.39.1",
    "eslint-config-next": "^15.0.3",
    "postcss": "8.5.6",
    "prisma": "^7.8.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "config": "prisma.config.ts"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
