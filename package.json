{
  "name": "ai-strategic-academy",
  "version": "0.1.0",
  "private": true,
  "description": "Closed academy LMS for AI Strategic Academy.",
  "scripts": {
    "analyze": "set ANALYZE=true&&next build",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-db.ps1 & next dev",
    "dev:next": "next dev",
    "build": "node scripts/clean-next-dev-types.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx scripts/assert-local-database.ts test:e2e && playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "tsx scripts/assert-local-database.ts db:push && prisma db push",
    "db:seed": "tsx scripts/assert-local-database.ts db:seed && tsx prisma/seed.ts",
    "certificate:issue-demo": "tsx scripts/assert-local-database.ts certificate:issue-demo && tsx scripts/issue-demo-certificate.ts",
    "users:provision": "tsx scripts/provision-users.ts",
    "users:create": "tsx scripts/create-users.ts",
    "users:check-demo": "tsx scripts/check-demo-users.ts",
    "course:create-demo": "tsx scripts/create-demo-course.ts",
    "postinstall": "tsx scripts/check-assets.ts",
    "banned-patterns": "node scripts/check-banned-patterns.mjs",
    "security:skills": "node scripts/check-security-skills.mjs",
    "security:dependencies": "npm audit --audit-level=high",
    "verify:security": "npm run security:skills && npm run security:dependencies",
    "verify:specs": "npx tsx scripts/validate-specs.ts",
    "verify": "npm run banned-patterns && npm run security:skills && npm run lint -- --max-warnings=0 && npm run typecheck && npm run test && npm run build && npm run verify:specs",
    "verify:release": "npm run verify:security && npm run lint -- --max-warnings=0 && npm run typecheck && npm run test && npx prisma validate && npm run db:generate && npm run build && npm run test:e2e",
    "lhci": "lhci autorun"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@next-auth/prisma-adapter": "1.0.7",
    "@node-rs/argon2": "2.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.52.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "5.91.2",
    "@tanstack/react-virtual": "^3.13.26",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/pm": "^2.11.7",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@upstash/redis": "^1.38.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "dompurify": "^3.4.5",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.16",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^3.14.0",
    "lucide-react": "0.468.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.7",
    "nuqs": "^2.8.9",
    "otplib": "^13.4.0",
    "pdf-lib": "1.17.1",
    "pg": "^8.20.0",
    "qrcode": "1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "usehooks-ts": "^3.1.1",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "3.3.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "24.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "1.5.5",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "10.4.22",
    "eslint": "9.39.1",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "8.5.6",
    "prisma": "^7.8.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "config": "prisma.config.ts"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
