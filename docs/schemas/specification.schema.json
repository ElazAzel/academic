{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Strategic Academy Specification",
  "type": "object",
  "required": ["title", "date", "status", "goals", "models", "architecture", "validation"],
  "properties": {
    "title": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "status": { "enum": ["draft", "proposed", "approved", "implemented", "deprecated"] },
    "goals": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "fields"],
        "properties": {
          "name": { "type": "string" },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "architecture": {
      "type": "object",
      "required": ["layers", "dataFlow"],
      "properties": {
        "layers": { "type": "array", "items": { "type": "string" } },
        "dataFlow": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule", "test"],
        "properties": {
          "rule": { "type": "string" },
          "test": { "type": "string" }
        }
      }
    }
  }
}
